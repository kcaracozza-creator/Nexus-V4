# Nexus Card System - Environment Configuration Template
# Copy this file to .env and fill in your values

# ========================================
# SYSTEM CONFIGURATION
# ========================================
NEXUS_MODE=desktop                    # Options: desktop, server, kiosk

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_TYPE=sqlite                        # Options: sqlite, postgresql, mysql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus_cards
DB_USER=nexus
DB_PASSWORD=your_password_here

# ========================================
# API CONFIGURATION
# ========================================
API_ENABLED=false
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
NEXUS_CARDS_URL=https://nexus-cards.com/api

# ========================================
# SYNC CONFIGURATION
# ========================================
SYNC_ENABLED=false
SYNC_INTERVAL=300                     # Sync interval in seconds
AUTO_UPLOAD=false                     # Auto-upload new scans to nexus-cards.com

# ========================================
# QUICKBOOKS INTEGRATION
# ========================================
QB_ENABLED=false
QB_COMPANY_FILE=
QB_USERNAME=
QB_PASSWORD=

# ========================================
# HARDWARE CONFIGURATION
# ========================================
SCANNER_ENABLED=true
CAMERA_ENABLED=true
IR_SENSOR_ENABLED=false
SCANNER_PORT=COM3                     # Adjust for your system
CAMERA_INDEX=0

# GPU Configuration
GPU_ENABLED=true
EGPU_ENABLED=false
GPU_DEVICE=auto                       # auto, cuda:0, cuda:1
GPU_MEMORY_FRACTION=0.9
MIXED_PRECISION=true

# SD Card Reader (Premium Feature)
SD_CARD_ENABLED=true
SD_AUTO_UPLOAD=false                  # Auto-upload on card insert (requires Premium)

# ========================================
# UI CONFIGURATION
# ========================================
UI_THEME=professional                 # Options: professional, classic, dark
UI_FULLSCREEN=false
UI_KIOSK_MODE=false                   # For Nexus OS deployment

# ========================================
# DEPLOYMENT-SPECIFIC SETTINGS
# ========================================
# Uncomment and customize for your deployment

# For multi-shop installations
# SHOP_ID=shop_001
# SHOP_NAME=My Card Shop

# For cloud deployments
# CLOUD_PROVIDER=aws                  # Options: aws, azure, gcp, digitalocean
# CLOUD_REGION=us-east-1

# For API authentication
# API_KEY=your_api_key_here
# API_SECRET=your_api_secret_here
