# =============================================================================
# NEXUS V4 - .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE / Editor
.vs/
.idea/
*.swp
*.swo
*.sublime-*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Node
node_modules/

# Environment / Secrets - NEVER COMMIT
.env
*.env.local
*.env.production
polygon_config.json

# =============================================================================
# LICENSE COMPLIANCE
# =============================================================================
assets/keyrune-master/
assets/fonts/keyrune.css

# =============================================================================
# DATA & RUNTIME (regenerated locally)
# =============================================================================

# Databases
*.db
*.sqlite

# Large datasets (fetch via API / scraper)
data/cards.csv
data/cards.json
data/JSON/
data/MASTER*/

# User / shop data
data/gestix_collection.csv
Collection_export*.csv
exports/*.csv
data/Import_Backups/
data/Inventory/

# Caches
data/cache/
data/SCRYFALL_CACHE/
data/price_cache.json
data/price_history.json
data/scans/
data/backups/
data/logs/
data/AI_LEARNING/
data/BI_REPORTS/
data/MARKETPLACE/
data/notebooks/
modules/scrapers/scryfall_data_cache.json
cache/

# Library data (regenerated at runtime)
nexus_library.json
data/nexus_library.json
data/nexus_library_backup.json
data/nexus_library_OLD_*.json

# =============================================================================
# LARGE ASSETS - DO NOT COMMIT
# =============================================================================

# Card images (downloaded at runtime)
assets/Card_Images/
assets/Generated_Cards/

# Blockchain build artifacts (regenerated by npm install / hardhat compile)
blockchain/node_modules/
blockchain/artifacts/
blockchain/cache/

# RL training checkpoints (regenerated by training)
nexus_v2/ai/robot_simulation/nexus_arm_curriculum/*.zip
nexus_v2/ai/robot_simulation/nexus_arm_curriculum/checkpoints/
training/

# =============================================================================
# BINARY / LARGE FILE TYPES
# =============================================================================
*.iso
*.exe
*.pkg
*.mp4
*.avi
*.mov
*.zip
*.tar.gz
*.rar
*.7z
*.xlsx
*.traineddata
*.lstm

# Whitelist specific zips if needed
# !path/to/specific.zip

# =============================================================================
# DEBUG / TEMP (clean repo, no cruft)
# =============================================================================
*.jpg
*.png
*.bmp
# Whitelist actual assets
!assets/**/*.jpg
!assets/**/*.png
!nexus_v2/assets/**/*.png
!nexus_v2/assets/**/*.jpg
!docs/**/*.png
!docs/**/*.jpg
!cad/**/*.png

# Wrangler cache
.wrangler/

# Test artifacts
test_library.json
*.docx
*.doc
*.pptx
